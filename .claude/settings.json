{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pip install -q -r \"${CLAUDE_PROJECT_DIR:-.}/tools/requirements.txt\" >/dev/null 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/tools/preflight_deploy_branch.sh\" 2>&1 || true"
          }
        ]
      }
    ]
  }
}
